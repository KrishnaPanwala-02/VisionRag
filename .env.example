# Copy this file to .env and fill in the real secret values. Do NOT commit .env with secrets.

# Django
DJANGO_SECRET_KEY=replace-with-your-secret-key

# Gemini Vision
GEMINI_API_KEY=replace-with-gemini-key

# Cloud LLMs
GROQ_API_KEYS=
TOGETHER_API_KEYS=
OPENROUTER_API_KEYS=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password
